# ============================================================
# SparqForge™ Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ---------- Core ----------
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/sparqforge
SESSION_SECRET=generate-a-random-32-char-string
TOKEN_ENCRYPTION_KEY=generate-a-random-32-byte-hex-string
LOG_LEVEL=info

# ---------- App URLs ----------
# APP_URL overrides auto-detected Replit URLs for OAuth callbacks
# APP_URL=https://your-app.replit.app
# CORS_ORIGIN=https://your-app.replit.app
# GOOGLE_CALLBACK_URL=/api/auth/google/callback

# ---------- Dev-only ----------
# Set to "true" to bypass authentication in development (NEVER in production)
DEV_AUTH_BYPASS=false

# ---------- Google OAuth ----------
# SparqForge-prefixed names take priority over generic names
# SparqForge_Google_Client_ID=
# SparqForge_Google_Client_Secret=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ---------- Twitter / X OAuth ----------
# X_SparqForge_X_API_Key=
# X_SparqForge_X_API_Secret=
# X_SparqForge_X_Access_Token=
# X_SparqForge_X_Access_Token_Secret=

# ---------- Instagram / Facebook OAuth ----------
# SparqForge_Instagram_App_ID=
# SparqForge_Instagram_App_Secret=

# ---------- LinkedIn OAuth ----------
# SparqForge_LinkedIn_Client_ID=
# SparqForge_LinkedIn_Client_Secret=

# ---------- AI Services ----------
# SparqForge_ElevenLabs_API_Key=

# ---------- Screenshot Service ----------
# SparqForge_ScreenshotOne_API_Key=
