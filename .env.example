# ============================================================
# SparqMake™ Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ---------- Core ----------
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/sparqmake
SESSION_SECRET=generate-a-random-32-char-string
TOKEN_ENCRYPTION_KEY=generate-a-random-32-byte-hex-string
LOG_LEVEL=info

# ---------- App URLs ----------
# APP_URL overrides auto-detected Replit URLs for OAuth callbacks
# APP_URL=https://your-app.replit.app
# CORS_ORIGIN=https://your-app.replit.app
# GOOGLE_CALLBACK_URL=/api/auth/google/callback

# ---------- Dev-only ----------
# Set to "true" to bypass authentication in development (NEVER in production)
DEV_AUTH_BYPASS=false

# ---------- Google OAuth ----------
# SparqMake-prefixed names take priority over generic names
# SparqMake_Google_Client_ID=
# SparqMake_Google_Client_Secret=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ---------- Twitter / X OAuth ----------
# X_SparqMake_X_API_Key=
# X_SparqMake_X_API_Secret=
# X_SparqMake_X_Access_Token=
# X_SparqMake_X_Access_Token_Secret=

# ---------- Instagram / Facebook OAuth ----------
# SparqMake_Instagram_App_ID=
# SparqMake_Instagram_App_Secret=

# ---------- LinkedIn OAuth ----------
# SparqMake_LinkedIn_Client_ID=
# SparqMake_LinkedIn_Client_Secret=

# ---------- AI Services ----------
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# SparqMake_ElevenLabs_API_Key=

# ---------- AI Model Overrides (optional) ----------
# CLAUDE_MODEL=claude-sonnet-4-6
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_TEXT_MODEL=gemini-2.5-flash-preview-05-20
# VEO_MODEL=veo-2.0-generate-001
# CLAUDE_CAPTION_COST_USD=0.01
# IMAGEN_PER_IMAGE_COST_USD=0.06

# ---------- Screenshot Service ----------
# SparqMake_ScreenshotOne_API_Key=
